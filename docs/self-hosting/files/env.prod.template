# /var/www/mixtape.prod/.env      — 640 mixtape-deploy:www-data
#
# Production environment. Fill the <PLACEHOLDER> values, then generate the key:
#   sudo -u www-data /usr/bin/php /var/www/mixtape.prod/artisan key:generate --force
#
# Anything not listed here falls back to the framework default in config/*.php.

APP_NAME=MixTape
APP_ENV=production
APP_KEY=                                   # php artisan key:generate --force
APP_DEBUG=false
APP_URL=https://<your-domain>

APP_LOCALE=de
APP_FALLBACK_LOCALE=de
APP_FAKER_LOCALE=de_DE

APP_MAINTENANCE_DRIVER=file

# --- Database -----------------------------------------------------------
# Postgres is localhost-only (Phase 1) and stays that way.
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=mixtape_prod
DB_USERNAME=mixtape_prod
DB_PASSWORD=<FROM /root/mixtape-prod-db.pw>

# --- Session / cache / queue --------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# HTTPS-only cookies. Safe from day one: prod is TLS-only (the :80 vhost is a
# 301), even before the real LE cert lands in Step 4.
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

CACHE_STORE=database
QUEUE_CONNECTION=database
FILESYSTEM_DISK=local

# --- Logging ------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=daily
# MUST be debug while MAIL_MAILER=log: the log mailer writes the rendered email
# at debug level, so anything higher silently discards every invite and
# verification mail. Raise this to `warning` once a real relay is configured
# (go-live Step 6) and mail actually leaves the box — otherwise every email,
# signed reset links included, sits in the production logs indefinitely.
LOG_LEVEL=debug
# LOG_LEVEL=warning                        # <-- flip to this together with MAIL_MAILER=smtp below

# --- Mail (go-live Step 6) ----------------------------------------------
# Never send directly from a home server — residential dynamic IP, no PTR, and
# on every blocklist, so mail is discarded (usually silently). Always relay.
#
# NOTE: if your relay offers both a *sandbox/testing* inbox and a *sending*
# product, take the credentials from the SENDING one. A sandbox host captures
# mail and never delivers it, so pointing production at it looks exactly like
# success while nobody ever receives anything.
#
# Uncomment the smtp block below (and LOG_LEVEL=warning above) once your
# sending domain is verified with the relay provider.
MAIL_MAILER=log
# MAIL_MAILER=smtp
# MAIL_HOST=<relay smtp host>
# MAIL_PORT=587
# MAIL_USERNAME=<relay username>
# MAIL_PASSWORD=<relay password>
# Leave MAIL_SCHEME UNSET. Laravel only accepts 'smtp'/'smtps' here and derives
# it from the port (465 -> smtps, else smtp + auto-STARTTLS). A value like 'tls'
# reaches Symfony's transport factory and throws UnsupportedSchemeException.
MAIL_FROM_ADDRESS="no-reply@<your-domain>"
MAIL_FROM_NAME="${APP_NAME}"
# If you set up a real inbox on the domain, consider a Reply-To on the
# notifications so replies to no-reply@ reach a human.

# --- Library scanner (php artisan app:update) ---------------------------
# Absolute server paths to each area of the collection. There are NO code
# defaults — an empty OR unset path disables that area (the scan skips it, no
# rows touched); a non-empty path that isn't a directory is a fatal error.
# podcast_shows is left empty unless you actually have podcasts.
MIXTAPE_MUSIC_PATH=/var/media/music
MIXTAPE_AUDIOBOOKS_PATH=/var/media/audiobooks
MIXTAPE_PODCAST_SHOWS_PATH=
# Where the scan e-mails a fatal error / empty-area / skipped-files alert.
# Empty -> log only (storage/logs/library.log), no e-mail.
MIXTAPE_SCAN_ALERT_EMAIL=<ops-address>

# --- Vite ---------------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"
# The dev-server vars (VITE_SERVER_ORIGIN / VITE_ALLOWED_HOSTS / VITE_HMR_*)
# are deliberately unset: prod serves built assets, there is no dev server.
