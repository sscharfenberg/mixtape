{
    "name": "mixtape",
    "description": "MixTape - self-hosted personal mp3 / audiobook collection player",
    "license": "UNLICENSED",
    "private": true,
    "version": "0.1.0",
    "type": "module",
    "engines": {
        "node": "^26.4.0",
        "npm": "^11.17.0"
    },
    "author": {
        "name": "Sven Scharfenberg"
    },
    "scripts": {
        "dev": "npm run preinstall && vite --host",
        "build": "npm run preinstall && npm run lint && run-p type-check \"build-only {@}\" --",
        "build-only": "vite build",
        "type-check": "vue-tsc --build",
        "lint": "eslint 'resources/**/*.{js,ts,vue}' --fix && stylelint 'resources/**/*.{vue,scss}' --fix --quiet-deprecation-warnings",
        "icons": "node ./resources/build/icons.ts -v -i",
        "format": "prettier --write resources/app/**/*",
        "preinstall": "node ./resources/build/checkNodeVersion.ts"
    },
    "dependencies": {
        "@inertiajs/vue3": "^3.3.1",
        "@sscharfenberg/progressbar": "^0.2.0",
        "normalize.css": "^8.0.1",
        "vue": "^3.5.38",
        "vue-i18n": "^11.4.6",
        "vue-input-otp": "^0.3.2"
    },
    "devDependencies": {
        "@types/minimist": "^1.2.5",
        "@types/node": "^25.9.3",
        "@types/semver": "^7.7.1",
        "@vitejs/plugin-vue": "^6.0.7",
        "@vue/eslint-config-prettier": "^10.2.0",
        "@vue/eslint-config-typescript": "^14.8.0",
        "@vue/tsconfig": "^0.9.1",
        "chalk": "^5.6.2",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^10.1.8",
        "eslint-import-resolver-typescript": "^4.4.5",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-vue": "^10.9.2",
        "jiti": "^2.7.0",
        "laravel-vite-plugin": "^3.1.0",
        "lightningcss": "^1.32.0",
        "minimist": "^1.2.8",
        "npm-run-all2": "^9.0.1",
        "prettier": "3.8.3",
        "sass-embedded": "^1.100.0",
        "semver": "^7.8.3",
        "sharp": "^0.35.1",
        "stylelint": "^17.13.0",
        "stylelint-config-standard-scss": "^17.0.0",
        "stylelint-config-standard-vue": "^1.0.0",
        "stylelint-order": "^8.1.1",
        "stylelint-scss": "^7.2.0",
        "svgo": "^4.0.1",
        "svgstore": "^3.0.1",
        "typescript": "~6.0.3",
        "vite": "^8.0.16",
        "vite-plugin-image-optimizer": "^2.0.3",
        "vite-plugin-vue-devtools": "^8.1.3",
        "vue-tsc": "^3.3.5"
    },
    "prettier": {
        "printWidth": 120,
        "tabWidth": 4,
        "semi": true,
        "singleQuote": false,
        "singleAttributePerLine": false,
        "trailingComma": "none",
        "bracketSpacing": true,
        "arrowParens": "avoid",
        "overrides": [
            {
                "files": "**/*.yml",
                "options": {
                    "tabWidth": 2
                }
            }
        ]
    },
    "allowScripts": {
        "vue-demi@0.14.10": true,
        "@parcel/watcher@2.5.6": true,
        "unrs-resolver@1.12.2": true,
        "fsevents@2.3.3": true
    }
}
